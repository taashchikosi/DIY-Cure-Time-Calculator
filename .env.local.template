# Supabase — REQUIRED (get from Supabase > Settings > Database)
# Port 6543 = pooler (for app queries). Port 5432 = direct (for migrations only).
DATABASE_URL="postgres://[user]:[pass]@[host]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgres://[user]:[pass]@[host]:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_KEY="[service-role-key-from-supabase-api-settings]"

# Upstash Redis — rate limiting on /api/calculate (free tier: 10K commands/day)
UPSTASH_REDIS_REST_URL="https://[redis-url].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[redis-token]"

# GitHub PAT — for GitHub Actions TDS verification cron
GITHUB_TOKEN="[github-personal-access-token-repo-scope]"

# Anthropic API — optional, only if adding AI features
ANTHROPIC_API_KEY="[anthropic-api-key]"

# Analytics (add after launch)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Affiliate links (add AFTER approval — see plan Section 6 timing requirements)
# Amazon: apply ONLY after 50+ daily visitors (180-day sale requirement risk)
NEXT_PUBLIC_AMAZON_TAG="[your-associate-tag]-20"
# Impact (Home Depot/Lowe's): apply after 10+ indexed pages with professional email
NEXT_PUBLIC_IMPACT_ID="[impact-partner-id]"

# AdSense: apply LAST — after 30+ pages + 60 days indexed + legal pages live
ADSENSE_CLIENT_ID="ca-pub-[id]"
